{
  "rules": {
    "classes": {
      ".read": true,
      ".indexOn": ["name"],

      "$classId": {
        ".write": true,
        ".validate": "newData.exists() == false || newData.hasChildren(['name'])",

        "name": {
          ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 80"
        },

        "subjects": {
          ".indexOn": ["name"],

          "$subjectId": {
            ".validate": "newData.exists() == false || newData.hasChildren(['name'])",

            "name": {
              ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 80"
            },

            "chapters": {
              ".indexOn": ["name"],

              "$chapterId": {
                ".validate": "newData.exists() == false || newData.hasChildren(['name'])",

                "name": {
                  ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 200"
                },

                "questions": {
                  ".indexOn": ["type"],

                  "$questionId": {
                    ".validate": "newData.exists() == false || newData.hasChildren(['type','question'])",

                    "type":     { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 60" },
                    "question": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 2000" },
                    "answer":   { ".validate": "newData.isString() && newData.val().length <= 20000" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

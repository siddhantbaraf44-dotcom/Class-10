{
  "rules": {
    ".read": false,
    ".write": false,

    "classes": {
      ".read": true,
      ".write": true,
      ".indexOn": ["name"],

      "$classId": {
        "subjects": {
          ".indexOn": ["name"],

          "$subjectId": {
            "chapters": {
              ".indexOn": ["name"],

              "$chapterId": {
                "questions": {
                  ".indexOn": ["type"]
                }
              }
            }
          }
        }
      }
    }
  }
}
